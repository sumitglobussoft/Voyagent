{
  "name": "@voyagent/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Voyagent canonical domain types, generated from the Pydantic source of truth.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "codegen:export": "uv run python ../../infra/scripts/export_schemas.py",
    "codegen:compile": "json2ts -i schemas.json -o src/generated.ts --additionalProperties false --style.singleQuote false --style.printWidth 100",
    "codegen": "pnpm run codegen:export && pnpm run codegen:compile",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist schemas.json"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0"
  }
}
