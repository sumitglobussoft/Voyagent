{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Voyagent Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "incremental": true,
    "allowJs": true,
    "plugins": [{ "name": "next" }]
  }
}
