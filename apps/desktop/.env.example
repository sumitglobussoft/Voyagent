# Base URL of the Voyagent FastAPI backend.
# The desktop shell talks to this over HTTP + SSE via @voyagent/sdk and
# also uses it for the in-house cookie/JWT auth endpoints
# (/api/auth/sign-in, /api/auth/sign-up, /api/auth/me, /api/auth/refresh,
# /api/auth/sign-out).
VITE_VOYAGENT_API_URL=https://voyagent.globusdemos.com

# Default tenant + actor for the chat session. The API derives both from
# the JWT and ignores the request body, but the chat component still
# requires them as props for local dev.
VITE_VOYAGENT_TENANT_ID=dev-tenant
VITE_VOYAGENT_ACTOR_ID=dev-user
