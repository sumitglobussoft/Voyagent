# Base URL of the Voyagent FastAPI backend.
# The desktop shell talks to this over HTTP + SSE via @voyagent/sdk.
VITE_VOYAGENT_API_URL=http://localhost:8000

# Default tenant + actor for the chat session. These are vestigial once
# Clerk auth is active — the API derives both from the JWT and ignores
# the request body — but the chat component still requires them as props.
VITE_VOYAGENT_TENANT_ID=dev-tenant
VITE_VOYAGENT_ACTOR_ID=dev-user

# ---- Clerk (desktop auth) ---- #
# Publishable key from the Clerk dashboard for the Voyagent desktop
# instance. Register voyagent://auth/callback as an allowed redirect URL
# on this instance before running.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
