{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voyagent",
  "version": "0.0.0",
  "identifier": "com.voyagent.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @voyagent/desktop dev",
    "beforeBuildCommand": "pnpm --filter @voyagent/desktop build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voyagent",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {}
  }
}
