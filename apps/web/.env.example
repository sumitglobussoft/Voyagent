NEXT_PUBLIC_VOYAGENT_API_URL=http://localhost:8000

# Server-side base URL for API calls from server components / route handlers.
# In the deploy network this points at the in-cluster nginx so we bypass the
# public edge. For local dev, leave unset and the public URL above is used.
VOYAGENT_INTERNAL_API_URL=http://nginx:80/api

# ------------------------------ Sentry (optional) ----------------------------
# Leave blank in dev — the app boots as a silent no-op without a DSN.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Server/edge-only DSN fallback. If unset, NEXT_PUBLIC_SENTRY_DSN is used.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Release + source-map upload (only used at build time).
SENTRY_ORG=
SENTRY_PROJECT_WEB=
SENTRY_AUTH_TOKEN=
VOYAGENT_VERSION=0.0.0-dev
