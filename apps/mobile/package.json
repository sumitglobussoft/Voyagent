{
  "name": "@voyagent/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "description": "Voyagent mobile app (Expo + React Native). Reports + desktop remote-control relay. Skeleton only — most surfaces are placeholders.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf .expo dist"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-camera": "~15.0.0",
    "expo-constants": "~16.0.0",
    "expo-linking": "~6.3.0",
    "expo-router": "~3.5.0",
    "expo-status-bar": "~1.12.0",
    "expo-system-ui": "~3.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-auth-session": "~5.5.0",
    "expo-web-browser": "~13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.74.0",
    "react-native-safe-area-context": "^4.10.0",
    "react-native-screens": "^3.31.0",
    "@voyagent/chat": "workspace:*",
    "@voyagent/core": "workspace:*",
    "@voyagent/sdk": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "^19.0.0",
    "@voyagent/config": "workspace:*",
    "typescript": "^5.6.0",
    "rimraf": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
