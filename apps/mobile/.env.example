# Base URL of the Voyagent FastAPI backend, read via expo-constants /
# process.env at build time.
EXPO_PUBLIC_VOYAGENT_API_URL=http://localhost:8000

# Dev tenant + actor until the API infers them exclusively from the JWT.
EXPO_PUBLIC_VOYAGENT_TENANT_ID=dev-tenant
EXPO_PUBLIC_VOYAGENT_ACTOR_ID=dev-user

# ---- Clerk (mobile auth) ---- #
# Publishable key from the Clerk dashboard for the Voyagent mobile
# instance. Find it under API Keys. Expo inlines EXPO_PUBLIC_* at
# build time.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
