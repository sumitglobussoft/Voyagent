# Base URL of the Voyagent FastAPI backend, read via process.env at
# build time. Production hits the hosted API; override for local dev.
EXPO_PUBLIC_VOYAGENT_API_URL=https://voyagent.globusdemos.com

# Dev tenant + actor until the API infers them exclusively from the JWT.
EXPO_PUBLIC_VOYAGENT_TENANT_ID=dev-tenant
EXPO_PUBLIC_VOYAGENT_ACTOR_ID=dev-user
