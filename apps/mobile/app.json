{
  "expo": {
    "name": "Voyagent",
    "slug": "voyagent",
    "scheme": "voyagent",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voyagent.mobile"
    },
    "android": {
      "package": "com.voyagent.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-camera"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "TODO-run-eas-init-in-apps-mobile"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/TODO-run-eas-init-in-apps-mobile"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
